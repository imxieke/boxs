alias ios='open -a /Applications/Xcode.app/Contents/Developer/Applications/Simulator.app'

alias pma="brew install"
alias pmr="brew uninstall"
alias pmu="brew update"
alias pmuu="brew upgrade"
alias pmi="brew info"
alias pmo="brew outdated --greedy-auto-updates"
alias pml="brew list --full-name | tr '' '\n'"
alias pms="brew search"
alias pmc="brew clean --prune=all"
